rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn() && exists(userPath());
    }

    function userDoc() {
      return get(userPath());
    }

    function userRole() {
      return hasUserDoc() && userDoc().data.role is string
        ? userDoc().data.role
        : '';
    }

    function isHod() {
      return isSignedIn() && (userRole() == 'HOD' || userRole() == 'hod');
    }

    function isTeacher() {
      return isSignedIn() &&
        (
          userRole() == 'Teacher' ||
          userRole() == 'teacher' ||
          userRole() == 'Staff' ||
          userRole() == 'staff'
        );
    }

    function isStudent() {
      return isSignedIn() &&
        (userRole() == 'Student' || userRole() == 'student');
    }

    function teacherDelegationDocId(ownerTeacherId, delegateTeacherId, classroomId) {
      return ownerTeacherId + "_" + delegateTeacherId + "_" + classroomId;
    }

    function hasActiveTeacherDelegation(ownerTeacherId, classroomId) {
      let specificPath = /databases/$(database)/documents/teacher_delegations/$(teacherDelegationDocId(ownerTeacherId, request.auth.uid, classroomId));
      return exists(specificPath) &&
        get(specificPath).data.isActive == true &&
        get(specificPath).data.ownerTeacherId == ownerTeacherId &&
        get(specificPath).data.delegateTeacherId == request.auth.uid &&
        request.time >= get(specificPath).data.startAt &&
        request.time <= get(specificPath).data.endAt;
    }

    function canAccessOwnPass() {
      return isSignedIn() &&
        (
          isHod() ||
          resource.data.studentId == request.auth.uid ||
          resource.data.teacherId == request.auth.uid ||
          resource.data.hodId == request.auth.uid
        );
    }

    function isPublicApprovedPass() {
      return resource.data.status == 'Approved';
    }

    function canWritePublicScanFields() {
      let changed = request.resource.data.diff(resource.data).changedKeys();
      return isPublicApprovedPass() &&
        resource.data.usedAt == null &&
        changed.hasOnly(['usedAt', 'usedBy', 'usedByDevice']) &&
        request.resource.data.usedAt is timestamp &&
        request.resource.data.usedBy is string &&
        request.resource.data.usedByDevice is string;
    }

    function isValidScanHistoryCreate() {
      return request.resource.data.passId is string &&
        request.resource.data.outcome is string &&
        request.resource.data.message is string &&
        request.resource.data.scannedAt is timestamp &&
        request.resource.data.scanSource is string &&
        request.resource.data.wasOffline is bool &&
        request.resource.data.pendingSync is bool;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /staff_invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isHod();
      allow update, delete: if isHod() && resource.data.hodId == request.auth.uid;
    }

    match /classrooms/{classroomId} {
      allow read: if isSignedIn();
      allow create: if isHod();
      allow update: if
        (isHod() && resource.data.hodId == request.auth.uid) ||
        (
          isTeacher() &&
          resource.data.teacherId == request.auth.uid
        ) ||
        (
          isSignedIn() &&
          (resource.data.teacherId == '' || resource.data.teacherId == request.auth.uid) &&
          request.resource.data.teacherId == request.auth.uid &&
          request.resource.data.hodId == resource.data.hodId &&
          request.resource.data.staffCode == resource.data.staffCode
        );
      allow delete: if isHod() && resource.data.hodId == request.auth.uid;
    }

    match /classroom_members/{memberId} {
      allow read: if isSignedIn();
      allow create: if
        isSignedIn() &&
        request.resource.data.studentId == request.auth.uid;
      allow delete: if isHod() || isTeacher();
      allow update: if false;
    }

    match /teacher_delegations/{delegationId} {
      allow read: if isSignedIn();
      allow create: if
        (isHod() && request.resource.data.hodId == request.auth.uid) ||
        (isTeacher() && request.resource.data.ownerTeacherId == request.auth.uid);
      allow update: if
        (isHod() && resource.data.hodId == request.auth.uid) ||
        (isTeacher() && resource.data.ownerTeacherId == request.auth.uid);
      allow delete: if
        (isHod() && resource.data.hodId == request.auth.uid) ||
        (isTeacher() && resource.data.ownerTeacherId == request.auth.uid);
    }

    match /gate_pass_requests/{requestId} {
      allow get: if canAccessOwnPass() || isPublicApprovedPass();
      allow list: if canAccessOwnPass();
      allow create: if isStudent() &&
        request.resource.data.studentId == request.auth.uid;
      allow update: if
        (
          isSignedIn() &&
          (
            resource.data.teacherId == request.auth.uid ||
            resource.data.hodId == request.auth.uid ||
            (
              isTeacher() &&
              hasActiveTeacherDelegation(resource.data.teacherId, resource.data.classroomId)
            )
          )
        ) ||
        canWritePublicScanFields();
      allow delete: if false;
    }

    match /gate_pass_scan_history/{scanId} {
      allow get, list: if isSignedIn();
      allow create: if isValidScanHistoryCreate();
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow get, list: if isSignedIn() && resource.data.toUserId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.toUserId == request.auth.uid;
      allow delete: if false;
    }
  }
}
